# Optional — defaults in settings.py work for local development
SECRET_KEY=change-this-secret-key-in-production
DATABASE_URL=sqlite:///./data/kedismart.db
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
# Origins only — never append /django-admin (causes doubled URLs).
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
# Local default: admin at /admin/  |  Production (same origin): django-admin
# DJANGO_ADMIN_URL_PREFIX=admin
# DJANGO_ADMIN_PUBLIC_PATH=/admin/
# Production / VPS (path-only PUBLIC_PATH — never a full https:// URL):
# APP_URL=https://kedismart.com
# FRONTEND_URL=https://kedismart.com
# DJANGO_ADMIN_URL_PREFIX=django-admin
# DJANGO_ADMIN_PUBLIC_PATH=/django-admin/

# ---------------------------------------------------------------------------
# Email / forgot-password (REQUIRED on VPS — OTP will not leave the server otherwise)
# Setting EMAIL_HOST alone switches Django to SMTP (no need to set EMAIL_BACKEND).
# Verify after deploy:
#   cd backend && source .venv/bin/activate
#   python manage.py check_password_reset --strict
#   python manage.py check_password_reset --send-to you@example.com
# ---------------------------------------------------------------------------
# Local DEV (prints OTP to gunicorn/console logs):
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Production SMTP example (Gmail App Password — enable 2FA first):
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# Quote the From header if it includes a display name (spaces / <>):
# DEFAULT_FROM_EMAIL="Kedi Smart <your@gmail.com>"
# SERVER_EMAIL="Kedi Smart <your@gmail.com>"

# Or Mailgun / any transactional provider:
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=postmaster@mg.yourdomain.com
# EMAIL_HOST_PASSWORD=...
# DEFAULT_FROM_EMAIL=Kedi Smart <noreply@yourdomain.com>

# Soft cart reservations (minutes)
# CART_RESERVE_MINUTES=30

# SSLCommerz — set both to enable Card / Mobile Banking at checkout
# SSLCOMMERZ_STORE_ID=
# SSLCOMMERZ_STORE_PASSWD=
# SSLCOMMERZ_SANDBOX=true
