# Local PC: talk to Django directly so staff-login sets the session cookie on :8000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_DJANGO_ADMIN_URL=http://localhost:8000/admin/
# Used for canonical URLs, Open Graph, sitemap, robots, RSS, JSON-LD
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional alias (same purpose as NEXT_PUBLIC_APP_URL):
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production / nginx (same origin) — deploy scripts write this on the VPS:
# NEXT_PUBLIC_API_URL=/api/v1
# BACKEND_URL=http://127.0.0.1:8002
# NEXT_PUBLIC_DJANGO_ADMIN_URL=/django-admin/
# NEXT_PUBLIC_APP_URL=https://kedismart.com
#
# After deploy, fill social URLs + Google/Bing verification in Django Admin → Site Settings
# so Organization.sameAs and search-console meta tags populate automatically.
